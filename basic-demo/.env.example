# Copy to .env and fill in your values.
# Required for FrogML SDK (schema, gRPC)
JF_URL=https://YOUR_INSTANCE.jfrog.io
JF_ACCESS_TOKEN=your-artifactory-access-token
JF_PROJECT=frogml

# Required for HuggingFace model download via Artifactory
HF_ENDPOINT=https://YOUR_INSTANCE.jfrog.io/artifactory/api/huggingfaceml/hf-remote
HF_TOKEN=your-artifactory-access-token
