# Copy to .env and fill in your values
# Required for Artifactory-sourced models and FrogML
JF_URL=https://YOUR_INSTANCE.jfrog.io
JF_ACCESS_TOKEN=your-artifactory-access-token
HF_ENDPOINT=https://YOUR_INSTANCE.jfrog.io/artifactory/api/huggingfaceml/hf-remote
HF_TOKEN=your-artifactory-access-token

# Optional
JF_PROJECT=frogml
JF_HF_REPO=hf-local
HF_MODEL_ID=distilbert-base-uncased-finetuned-sst-2-english

# DevOps Helper: JFrog repo for uploading fine-tuned models (default: devops-helper-llms)
# JF_MODEL_REPO=devops-helper-llms
